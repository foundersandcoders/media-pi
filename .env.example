# --- record.sh ---------------------------------------------------------------

# Input device/flags for ffmpeg (UVC camera). Output fps is pinned separately via
# VIDEO_FPS (-r), so frame counts map to a fixed duration.
FFMPEG_INPUT_ARGS=

# Where recordings and logs are written (defaults shown).
# RECORDINGS_DIR=./recordings
# LOG_DIR=./logs

# Minimum free disk space in MB before refusing to start (default 500).
# DISK_SPACE_MIN_MB=500

# Frames per recording segment before ffmpeg rotates to the next file (default 24000).
# We re-encode with libx264 and force a keyframe at every split frame, so each segment
# is exactly SEGMENT_FRAMES frames. With VIDEO_FPS pinned (CFR), 24000 @ 30fps = 13:20.
# MAX_SESSION_HOURS bounds the generated split-frame list (a session longer than this
# stops splitting — bump it if needed).
# SEGMENT_FRAMES=24000
# VIDEO_FPS=30
# MAX_SESSION_HOURS=12

# PID file location (default shown). Change if running multiple instances.
# PID_FILE=/tmp/fac-recorder.pid

# --- upload.sh ---------------------------------------------------------------

# GraphQL API — used for register and confirm steps.
FAC_API_URL=
FAC_API_KEY=

# MinIO credentials — used by rclone for chunked multipart upload.
MINIO_ENDPOINT=https://your-minio-host
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=recordings

# &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
# new chunk — scaffold, remove on implementation
# &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
# --- fetch_events.sh ---------------------------------------------------------

# REST endpoint the Pi polls for its lesson schedule.
FAC_SCHEDULE_URL=     # e.g. https://server/pi/upcoming-events
# Read-only API key, scope media-pi:schedule (separate from FAC_API_KEY).
FAC_SCHEDULE_KEY=
# Seconds between event polls (default 300).
# POLL_INTERVAL=300
# &&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
