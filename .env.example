# --- record.sh ---------------------------------------------------------------

# Commands for UVC
FFMPEG_INPUT_ARGS=
# VIDEO_CODEC=copy

# Where recordings and logs are written (defaults shown).
# RECORDINGS_DIR=./recordings
# LOG_DIR=./logs

# Minimum free disk space in MB before refusing to start (default 500).
# DISK_SPACE_MIN_MB=500

# PID file location (default shown). Change if running multiple instances.
# PID_FILE=/tmp/fac-recorder.pid

# --- upload.sh ---------------------------------------------------------------

# GraphQL API — used for register and confirm steps.
FAC_API_URL=
FAC_API_KEY=

# MinIO credentials — used by rclone for chunked multipart upload.
MINIO_ENDPOINT=https://your-minio-host
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=recordings
